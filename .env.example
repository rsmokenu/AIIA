# AIIA Environment Configuration
NODE_ENV=development
PORT=3000

# API Key
GEMINI_API_KEY=your_key_here

# Rate Limiting (requests per window)
AIIA_RATE_LIMIT_WINDOW_MS=900000
AIIA_RATE_LIMIT_MAX=100

# JSON Payload Limit
AIIA_JSON_LIMIT=1mb

# CORS (comma-separated origins, empty = allow all)
AIIA_CORS_ORIGINS=

# Trust Proxy (false, true, or hop count)
AIIA_TRUST_PROXY=false

# Logging (max file size in bytes, max files to retain)
AIIA_LOG_MAX_SIZE=5242880
AIIA_LOG_MAX_FILES=5

# LLM Cache (TTL in ms, cleanup interval in ms)
AIIA_CACHE_TTL_MS=3600000
AIIA_CACHE_CLEANUP_INTERVAL_MS=600000
